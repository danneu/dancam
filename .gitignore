# macOS
.DS_Store

# Xcode / Swift (app/)
*.xcuserstate
xcuserdata/
DerivedData/
build/
*.xcworkspace/xcuserdata/
.swiftpm/
Package.resolved

# Python / Raspberry Pi (raspi/)
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/

# Rust / Raspberry Pi service (raspi/)
/raspi/service/target/
/.dancam-development-image/
# Mock recorder scratch dirs (.mock-rec, .mock-rec-clips, ...). The assets/clips
# rules guard the tracked fixtures dir against a recorder run pointed there.
/raspi/service/.mock-rec*/
/raspi/service/assets/clips/state/
/raspi/service/assets/clips/time/

# Secrets / local config (never commit Wi-Fi creds, keys, etc.)
*.local
.env
secrets/

# Claude Code personal/local settings (shared config lives in settings.json)
.claude/settings.local.json

# Logs and captured media (never commit footage)
*.log
*.h264
*.ts
*.mp4
recordings/

# mdBook build output
/book/

# Third-party source references (seeded via `just fetch-references`)
references/
/plans/wip
/plans/icebox
