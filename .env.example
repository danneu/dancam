# Per-machine connection settings for the dancam Pi.
# Copy this file to .env and edit the values used to personalize development cards.

# SSH target for the Pi. The user is created during first-boot commissioning.
DANCAM_HOST=pi@dancam.local

# Private key used for SSH/Ansible connections to the Pi.
DANCAM_SSH_KEY=~/.ssh/id_ed25519

# Home Wi-Fi used by the Pi's fixed dancam-home NetworkManager profile.
DANCAM_HOME_WIFI_SSID=
DANCAM_HOME_WIFI_PSK=

# WPA2 password for the fixed dancam-dev development access point.
DANCAM_DEV_AP_PSK=
