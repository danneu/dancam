# Per-machine connection settings for the dancam Pi.
# Copy this file to .env and edit the values for the Raspberry Pi you flashed.

# SSH target for the Pi. The user must match the Raspberry Pi Imager username.
DANCAM_HOST=pi@dancam.local

# Private key used for SSH/Ansible connections to the Pi.
DANCAM_SSH_KEY=~/.ssh/id_ed25519

# NetworkManager connection name for the Pi's home Wi-Fi profile.
# Find it on the Pi with: nmcli connection show
DANCAM_HOME_WIFI=preconfigured
