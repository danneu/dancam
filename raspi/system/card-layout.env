# Card geometry shared by production-image assembly, first-boot commissioning,
# and development-card partitioning.
DANCAM_ALIGN_SECTORS=8192
# Accept nominal 32 GB cards down to the designed 60,000,000-sector floor.
DANCAM_MIN_TOTAL_SECTORS=60000000
DANCAM_MIN_CARD_BYTES=30720000000
DANCAM_DATA_PERCENT=95
DANCAM_BOOT_SIZE_SECTORS=1048576
DANCAM_DEVELOPMENT_ROOT_SIZE_SECTORS=16777216
DANCAM_DEVELOPMENT_PERSIST_SIZE_SECTORS=2097152
DANCAM_DEVELOPMENT_INITIAL_DATA_SIZE_SECTORS=262144
DANCAM_PRODUCTION_ROOT_SIZE_SECTORS=8388608
DANCAM_PRODUCTION_PERSIST_SIZE_SECTORS=1048576
DANCAM_PRODUCTION_INITIAL_DATA_SIZE_SECTORS=262144
DANCAM_PERSIST_LABEL=dancam-persist
DANCAM_DATA_LABEL=dancam-data
