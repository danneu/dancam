LABEL=bootfs /boot/firmware vfat defaults,noatime 0 2
LABEL=rootfs / ext4 defaults,noatime,errors=remount-ro 0 1
LABEL={{ dancam_persist_label }} /persist ext4 noatime,errors=remount-ro,nofail,x-systemd.device-timeout=10s 0 2
LABEL={{ dancam_data_label }} /data ext4 noatime,errors=remount-ro,nofail,x-systemd.device-timeout=10s 0 2
/persist/journal /var/log/journal none bind,nofail 0 0
